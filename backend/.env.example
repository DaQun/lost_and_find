# ================================================================
# Lost & Find Backend - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================================

# ----------------------------------------------------------------
# App
# ----------------------------------------------------------------
NODE_ENV=development
PORT=3000
# 本地开发改为你的局域网 IP，扫码才能跳到正确地址
# 例如: FRONTEND_URL=http://192.168.100.219:5173
FRONTEND_URL=http://localhost:5173

# ----------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lost_and_find

# ----------------------------------------------------------------
# Redis
# ----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank if Redis has no password
REDIS_PASSWORD=

# ----------------------------------------------------------------
# JWT
# ----------------------------------------------------------------
# Use a long, random string in production (e.g. `openssl rand -hex 64`)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------------------------------
# SMS (mock mode — set SMS_ENABLED=true and configure a real
# provider such as Aliyun / Tencent Cloud in production)
# ----------------------------------------------------------------
SMS_ENABLED=false
# Fixed OTP code used when SMS_ENABLED=false (dev only)
SMS_TEST_CODE=123456
